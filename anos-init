#!/bin/sh
# 🦾 AnosOS Init — PID 1
# Boot sequence: mount → network → anosd → anos-cli

echo ""
echo "╔══════════════════════════════════════════╗"
echo "║       🦾 AnosOS — AI Native OS          ║"
echo "║          v0.10.2 — booting...           ║"
echo "╚══════════════════════════════════════════╝"
echo ""

# ── Mount virtual filesystems ──
mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev
mkdir -p /dev/pts /tmp /run
mount -t devpts devpts /dev/pts

# ── Network: bring up + DHCP ──
echo "🌐 Setting up network..."
NET_ONLINE=false

# Load common network drivers
for mod in e1000 e1000e r8169 virtio_net tg3; do
    modprobe $mod 2>/dev/null
done

# Try DHCP on each interface
for iface in eth0 enp0s3 ens3 ens4; do
    if [ -e /sys/class/net/$iface ]; then
        ip link set $iface up 2>/dev/null
        udhcpc -i $iface -n -q -t 5 2>/dev/null && NET_ONLINE=true && echo "🌐 Connected: $iface" && break
    fi
done

if $NET_ONLINE; then
    echo "🟢 AI Mode — DeepSeek v4 Pro"
else
    echo "🟡 Offline Mode — local tools only"
fi

# ── Set hostname ──
hostname anos 2>/dev/null || echo "anos" > /proc/sys/kernel/hostname

# ── Start Anos Daemon ──
export ANOS_DIR=/opt/anos
export ANOS_SOCKET=/tmp/anos.sock
export ANOS_OFFLINE="$NET_ONLINE"  # true=online, false=offline (inverted for env)

# Pass network status to daemon
mkdir -p /opt/anos/config

# Start daemon
/usr/bin/anosd &
ANOSD_PID=$!

# Wait for socket
echo "🦾 Starting AI daemon..."
for i in $(seq 1 30); do
    [ -S /tmp/anos.sock ] && break
    sleep 0.1
done

if [ -S /tmp/anos.sock ]; then
    echo "🦾 Anos ready!"
else
    echo "⚠️ Anos daemon not responding — starting safe shell"
    exec /bin/sh
fi

# Set up TTY
[ -e /dev/tty1 ] || mknod /dev/tty1 c 4 1 2>/dev/null
[ -e /dev/tty2 ] || mknod /dev/tty2 c 4 2 2>/dev/null

# Clear screen
printf "\033[2J\033[H"

# ── Launch Anos CLI on tty1 ──
echo "🦾 Launching Anos CLI..."
exec /usr/bin/anos-cli
