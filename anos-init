#!/bin/sh
# 🦾 AnosOS Init — PID 1 with multi-user support
# Spawns getty on tty1-tty3 with respawn, anosd in background
#
# On tty1: auto-launch Anos CLI after login
# On tty2: root fallback shell
# On tty3: administrator shell

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║       🦾 AnosOS — AI Native OS              ║"
echo "║          v0.11.0 — booting...               ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

# ── 1. Mount virtual filesystems ──
echo "${CYAN}📀 Mounting filesystems...${NC}"
mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev
mkdir -p /dev/pts /tmp /run /home/anos
mount -t devpts devpts /dev/pts

# ── 2. Ensure basic devices ──
for dev in tty0 tty1 tty2 tty3 tty4 console null zero random urandom; do
    [ -e "/dev/$dev" ] || mknod "/dev/$dev" c 4 "$(echo "$dev" | sed 's/tty//')" 2>/dev/null || true
done
[ -e /dev/console ] || mknod /dev/console c 5 1 2>/dev/null || true
[ -e /dev/null ] || mknod /dev/null c 1 3 2>/dev/null || true
[ -e /dev/tty0 ] || mknod /dev/tty0 c 4 0 2>/dev/null || true

# ── 3. Network ──
echo "${CYAN}🌐 Setting up network...${NC}"
NET_ONLINE=false

for mod in e1000 e1000e r8169 virtio_net tg3; do
    modprobe $mod 2>/dev/null
done

for iface in eth0 enp0s3 ens3 ens4; do
    if [ -e "/sys/class/net/$iface" ]; then
        ip link set "$iface" up 2>/dev/null
        udhcpc -i "$iface" -n -q -t 5 2>/dev/null && NET_ONLINE=true && echo "  ✅ Connected: $iface" && break
    fi
done

# ── 4. Hostname ──
hostname anos 2>/dev/null || echo "anos" > /proc/sys/kernel/hostname
echo "127.0.0.1 localhost" > /etc/hosts
echo "::1       localhost" >> /etc/hosts

# ── 5. Setup Anos environment ──
export ANOS_DIR=/opt/anos
export ANOS_SOCKET=/tmp/anos.sock
export ANOS_OFFLINE="false"
$NET_ONLINE && export ANOS_OFFLINE="true"

mkdir -p /opt/anos/config /home/anos/.anos
chown anos:anos /home/anos /home/anos/.anos 2>/dev/null || true
ln -sf /opt/anos /home/anos/.anos 2>/dev/null || true

# ── 6. Start Anos Daemon (background) ──
echo "${CYAN}🦾 Starting AI daemon...${NC}"
/usr/bin/anosd &
ANOSD_PID=$!

# Wait for socket (max 5s, don't block boot)
for i in $(seq 1 50); do
    [ -S /tmp/anos.sock ] && break
    sleep 0.1
done

if [ -S /tmp/anos.sock ]; then
    echo "  ✅ Anos daemon ready"
else
    echo "  ⚠️  Anos daemon not responding — continuing boot"
fi

# ── 7. Print login banner ──
clear 2>/dev/null || printf "\033[2J\033[H"
echo ""
echo "╔══════════════════════════════════════════════╗"
echo "║       🦾 AnosOS — AI Native OS              ║"
echo "║          v0.11.0 — Ready                    ║"
echo "╠══════════════════════════════════════════════╣"
if $NET_ONLINE; then
    echo "║  🌐 Network: Online                         ║"
    echo "║  🧠 AI:      DeepSeek v4 Pro                ║"
else
    echo "║  🌐 Network: Offline (local tools only)     ║"
fi
echo "╠══════════════════════════════════════════════╣"
echo "║                                              ║"
echo "║  Default login:  anos / anos                 ║"
echo "║  ⚠️  CHANGE PASSWORD on first login!        ║"
echo "║                                              ║"
echo "╚══════════════════════════════════════════════╝"
echo ""

# ── 8. Spawn getty processes with respawn ──
# tty1: anos user → auto anos-cli
# tty2: root fallback
# tty3: admin shell
#
# Store PID → tty mapping for respawn
TTY_PIDS=""

spawn_getty() {
    local tty="$1"
    local baud="${2:-38400}"
    /sbin/getty "$baud" "$tty" &
    local pid=$!
    echo "$tty:$pid"
}

respawn_getty() {
    local tty="$1"
    local baud="${2:-38400}"
    while true; do
        /sbin/getty "$baud" "$tty"
        sleep 1  # Brief pause before respawn
    done
}

# Spawn each getty in background with respawn wrapper
for tty in tty1 tty2 tty3; do
    respawn_getty "$tty" 38400 &
    TTY_PIDS="$TTY_PIDS $tty:$!"
done

# ── 9. PID 1: reap children, keep system alive ──
echo "🦾 Init: system ready, waiting for logins..."

# Trap common signals for clean shutdown
cleanup() {
    echo ""
    echo "🦾 Shutting down..."
    kill $ANOSD_PID 2>/dev/null || true
    kill $(jobs -p) 2>/dev/null || true
    umount -a -r 2>/dev/null || true
    echo "Power down."
    exit 0
}
trap cleanup SIGTERM SIGINT SIGUSR1

# Main loop: reap zombies, keep running
while true; do
    wait -n 2>/dev/null || true
    # wait -n returns when any child exits; the respawn wrapper
    # will restart the getty automatically
done
